# 1. 进入项目目录
cd E:\studyWork\Alone-Michael.github.io

# 2. 安装 nvm（如果还没安装）

# 3. 创建 .nvmrc 文件
echo "18.20.8" > .nvmrc

# 4. 安装并切换到指定版本
nvm install 18.20.8
nvm use 18.20.8

# 5. 清理之前的 node_modules（重要！）
rm -rf node_modules
rm -f package-lock.json

# 6. 重新安装依赖
npm cache clean --force
npm install

# 7. 验证修复
node -v  # 应该显示 18.20.8
hexo version
hexo clean && hexo s